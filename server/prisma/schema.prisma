generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Utilisateur {
  id        Int      @id @default(autoincrement())
  nom       String
  email     String   @unique
  motDePasse String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        Int      @id @default(autoincrement())
  reference String   @unique
  nom       String
  prenom    String?
  telephone String?
  email     String?  @unique
  adresse   String?
  categorie String   @default("occasionnel")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  commandes Commande[]
  devis     Devis[]
}

model Devis {
  id          Int         @id @default(autoincrement())
  reference   String      @unique
  clientId    Int
  client      Client      @relation(fields: [clientId], references: [id])
  statut      String      @default("en_attente")
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lignes      LigneDevis[]
  commande    Commande?
}

model LigneDevis {
  id          Int      @id @default(autoincrement())
  devisId     Int
  devis       Devis    @relation(fields: [devisId], references: [id])
  designation String
  quantite    Float
  prixUnitaire Float   @default(0)
  montant     Float    @default(0)
  ordre       Int      @default(0)
}

model Commande {
  id          Int             @id @default(autoincrement())
  reference   String          @unique
  clientId    Int
  client      Client          @relation(fields: [clientId], references: [id])
  devisId     Int?            @unique
  devis       Devis?          @relation(fields: [devisId], references: [id])
  statut      String          @default("en_attente")
  dateCommande DateTime       @default(now())
  dateLivraison DateTime?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lignes      LigneCommande[]
  paiements   Paiement[]
  livraisons  Livraison[]
}

model LigneCommande {
  id           Int       @id @default(autoincrement())
  commandeId   Int
  commande     Commande  @relation(fields: [commandeId], references: [id])
  designation  String
  quantite     Float
  quantiteLivree Float   @default(0)
  prixUnitaire Float     @default(0)
  montant      Float     @default(0)
  ordre        Int       @default(0)
}

model Livraison {
  id          Int             @id @default(autoincrement())
  reference   String          @unique
  commandeId  Int
  commande    Commande        @relation(fields: [commandeId], references: [id])
  dateLivraison DateTime      @default(now())
  notes       String?
  createdAt   DateTime        @default(now())
  lignes      LigneLivraison[]
}

model LigneLivraison {
  id            Int       @id @default(autoincrement())
  livraisonId   Int
  livraison     Livraison @relation(fields: [livraisonId], references: [id])
  ligneCommandeId Int
  quantiteLivree Float
}

model Paiement {
  id          Int      @id @default(autoincrement())
  commandeId  Int
  commande    Commande @relation(fields: [commandeId], references: [id])
  montant     Float
  statut      String   @default("recu")
  notes       String?
  createdAt   DateTime @default(now())
}

model Stock {
  id          Int      @id @default(autoincrement())
  designation String
  quantite    Float
  unite       String
  seuilAlerte Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}